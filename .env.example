# ==========================================
# VARIABLES DE ENTORNO - ILSAN MES
# ==========================================
# Copia este archivo a .env y completa los valores

# Base de datos MySQL
MYSQL_HOST=tu-host-mysql.com
MYSQL_PORT=3306
MYSQL_DATABASE=nombre_base_datos
MYSQL_USER=usuario_mysql
# Alternativa: MYSQL_USERNAME=usuario_mysql
MYSQL_PASSWORD=contraseña_mysql
MYSQL_POOL_SIZE=50

# Flask
# OBLIGATORIA. Firma las cookies de sesion. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Si no se define y MES_ENV=production, la app NO arranca (fail-loud).
# En dev/local sin definirla se usa una clave efimera (las sesiones se
# invalidan al reiniciar).
SECRET_KEY=tu-clave-secreta-muy-segura-aqui

# Entorno: development (default) | production.
# En production se exige SECRET_KEY.
MES_ENV=development

# Cookie de sesion segura (solo bajo HTTPS). Default 0 para server local
# en HTTP. Ponlo en 1 si sirves la app por HTTPS.
MES_SESSION_COOKIE_SECURE=0

# Password inicial del usuario 'admin' al sembrar la BD por primera vez.
# Si se deja vacio, se genera una aleatoria y se muestra UNA vez en el log.
MES_ADMIN_PASSWORD=

# Nivel de logging: DEBUG | INFO (default) | WARNING | ERROR.
MES_LOG_LEVEL=INFO

# Opcional: Configuración de zona horaria
# TZ=America/Mexico_City
