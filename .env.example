# ==========================================
# VARIABLES DE ENTORNO - ILSAN MES
# ==========================================
# Copia este archivo a .env y completa los valores

# Base de datos MySQL
MYSQL_HOST=tu-host-mysql.com
MYSQL_PORT=3306
MYSQL_DATABASE=nombre_base_datos
MYSQL_USER=usuario_mysql
# Alternativa: MYSQL_USERNAME=usuario_mysql
MYSQL_PASSWORD=contraseña_mysql
MYSQL_POOL_SIZE=50

# Flask
# OBLIGATORIA. Firma las cookies de sesion. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Si no se define, la app NO arranca. Todas las instancias del servidor deben
# usar exactamente la misma clave para conservar las sesiones.
SECRET_KEY=tu-clave-secreta-muy-segura-aqui

# Entorno: development (default) | production.
MES_ENV=development

# Nombre exclusivo para evitar colisiones con otras aplicaciones del host.
MES_SESSION_COOKIE_NAME=mes_ilsan_session

# Cookie de sesion segura (solo bajo HTTPS). Default 0 para server local
# en HTTP. Ponlo en 1 si sirves la app por HTTPS.
MES_SESSION_COOKIE_SECURE=0

# Password inicial del usuario 'admin' al sembrar la BD por primera vez.
# Si se deja vacio, se genera una aleatoria y se muestra UNA vez en el log.
MES_ADMIN_PASSWORD=

# Nivel de logging: DEBUG | INFO (default) | WARNING | ERROR.
MES_LOG_LEVEL=INFO

# Opcional: Configuración de zona horaria
# TZ=America/Mexico_City

# Asistente IA (la clave siempre permanece en el servidor)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# Secreto independiente para anonimizar usuarios con HMAC. Si se omite,
# el servidor usa SECRET_KEY; en producción se recomienda definirlo.
AI_SAFETY_HMAC_KEY=
AI_DAILY_REQUEST_LIMIT=50
AI_DAILY_TOKEN_LIMIT=250000
AI_DAILY_ARTIFACT_LIMIT=10
AI_MAX_OUTPUT_TOKENS=2500
AI_MAX_TOOL_CALLS=6
AI_TOOL_MAX_ROWS=200
AI_AUTO_EXPORT_ROW_THRESHOLD=50
AI_ARTIFACT_MAX_ROWS=10000
AI_ARTIFACT_MAX_BYTES=20971520
AI_ARTIFACT_RETENTION_DAYS=30
# Tarifas opcionales por millón de tokens para estimación interna de costo.
AI_INPUT_COST_PER_MILLION=0
AI_OUTPUT_COST_PER_MILLION=0
